generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ADVERTISER
  PUBLISHER
}

enum CampaignStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  PAUSED
  COMPLETED
}

model User {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  password    String
  role        UserRole
  balance_usd Decimal @default(0) @db.Decimal(12,2)

  campaigns Campaign[]
  adZones   AdZone[]
  publisherSites PublisherSite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

model PublisherSite {
  id          String   @id @default(uuid())
  publisherId String
  publisher   User     @relation(fields: [publisherId], references: [id], onDelete: Cascade)

  domain       String
  adsTxtUrl    String
  expectedText String
  verified     Boolean  @default(false)
  verifiedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([publisherId, domain])
  @@index([publisherId])
  @@index([verified])
}

model Campaign {
  id String @id @default(uuid())

  advertiserId String
  advertiser   User   @relation(fields: [advertiserId], references: [id], onDelete: Cascade)

  campaignName String

  totalBudget Decimal @db.Decimal(12, 2)
  dailyBudget Decimal @db.Decimal(12, 2)
  maxCpc      Decimal @db.Decimal(10, 2)

  targetCountries String[]
  targetDevices   String[]

  creativeType String?
  creativeUrl  String?
  creativeHtml String?

  status CampaignStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([advertiserId])
  @@index([status])
  @@index([advertiserId, status])
}

model AdZone {
  id String @id @default(uuid())

  publisherId String
  publisher   User   @relation(fields: [publisherId], references: [id], onDelete: Cascade)

  zoneName String

  width  Int
  height Int

  layoutType String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([publisherId])
}

model BlacklistedIp {
  id        String   @id @default(uuid())
  ipAddress String   @unique
  source    String
  reason    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ipAddress])
  @@index([source])
}
