generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ADVERTISER
  PUBLISHER
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

model User {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  password    String
  role        UserRole
  balance_usd Decimal  @db.Decimal(12, 2)

  campaigns Campaign[]
  adZones   AdZone[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

model Campaign {
  id String @id @default(uuid())

  advertiserId String
  advertiser   User   @relation(fields: [advertiserId], references: [id], onDelete: Cascade)

  campaignName String

  totalBudget Decimal @db.Decimal(12, 2)
  dailyBudget Decimal @db.Decimal(12, 2)
  maxCpc      Decimal @db.Decimal(10, 2)

  targetCountries String[]
  targetDevices   String[]

  status CampaignStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([advertiserId])
  @@index([status])
  @@index([advertiserId, status])
}

model AdZone {
  id String @id @default(uuid())

  publisherId String
  publisher   User   @relation(fields: [publisherId], references: [id], onDelete: Cascade)

  zoneName String

  width  Int
  height Int

  layoutType String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([publisherId])
}
