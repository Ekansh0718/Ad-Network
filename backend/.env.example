DATABASE_URL="postgresql://postgres:change-me@localhost:5432/adnetwork?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN=1d
NODE_ENV=development
PORT=3000

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

CLICKHOUSE_URL=http://127.0.0.1:8123
CLICKHOUSE_DB=analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

PUBLIC_TAG_URL=http://localhost:3000/assets/publisher_tag.js
FRONTEND_DIR=../frontend
CAMPAIGN_CACHE_SYNC_ENABLED=true
CLICKHOUSE_INGESTION_ENABLED=true
# Path to a GeoLite2-Country.mmdb file. Defaults to the bundled MaxMind test
# fixture (test/fixtures/geoip) so serving works out of the box in dev/CI.
# Get a real, free-tier file at https://www.maxmind.com/en/geolite2/signup
# and point this at it for production-accurate geolocation.
GEOIP_DB_PATH=
VELOCITY_IMPRESSION_LIMIT=2
VELOCITY_IMPRESSION_WINDOW_SECONDS=30
VELOCITY_CLICK_LIMIT=3
VELOCITY_CLICK_WINDOW_SECONDS=60
